# ============================================================================
#  Drissman backend — variables d'environnement de déploiement.
#  Copier ce fichier en `.env` dans /home/gi/drissman sur le serveur yowyob
#  et remplir les vraies valeurs. NE JAMAIS COMMITER le .env rempli.
# ============================================================================

# --- PostgreSQL (base dédiée `drissman`, à demander à l'admin infra) --------
DB_USERNAME=drissman
DB_PASSWORD=<mot-de-passe-fourni-par-l-admin>

# --- kernel-core : identité machine (ClientApplication) ---------------------
# En interne Docker le KERNEL_BASE_URL est déjà fixé par le compose.
# NB : `prod-platform-backend` est la ClientApplication PARTAGÉE de la plateforme,
# et 1111...1111 est le TENANT PARTAGÉ par défaut. À terme, Drissman devrait avoir
# sa propre ClientApplication et son propre espace/tenant (cf. guide KSM).
KERNEL_CLIENT_ID=prod-platform-backend
KERNEL_API_KEY=<api-key-kernel>
KERNEL_TENANT_ID=11111111-1111-1111-1111-111111111111

# MODÈLE A : organisation kernel UNIQUE de Drissman (l'opérateur de la marketplace).
# Les auto-écoles ne sont PAS des organisations kernel — elles restent internes.
# À créer une seule fois à la main sur https://ksm.yowyob.com :
#   business actor approuvé -> créer un espace -> créer l'organisation -> souscrire
#   les services (ACCOUNTING, BILLING, CASHIER, HRM, FILE, KYC, NOTIFICATION).
# Laisser vide = appels org-scopés ignorés proprement (KERNEL_MIRROR outcome=SKIP).
KERNEL_ORGANIZATION_ID=<uuid-organisation-drissman>

# --- Secrets applicatifs Drissman -------------------------------------------
# JWT_SECRET : >= 256 bits, générer par ex. avec `openssl rand -base64 48`
JWT_SECRET=<secret-jwt-fort>
SUPERADMIN_SECRET=<code-secret-creation-superadmin>

# --- Yowyob Payment (paiement carte Stripe) ----------------------------------
# Compte de service + wallet plateforme (créer sur payment-dev.yowyob.com).
PAYMENT_EMAIL=payments@drissman.cm
PAYMENT_PASSWORD=<mot-de-passe-compte-paiement>
PAYMENT_WALLET_ID=<uuid-du-wallet-plateforme>

# --- CORS : origines du frontend, séparées par des virgules -----------------
APP_CORS_ALLOWED_ORIGINS=https://drissman0.vercel.app,https://drissman.yowyob.com

# ============================================================================
#  Frontend (Vercel) — variables à saisir dans le dashboard Vercel :
#    NEXT_PUBLIC_API_URL=https://drissman.yowyob.com/drissman-api/api
# ============================================================================
